<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <SampleManager>SAMPLEMANAGERPATH</SampleManager>
    <AssemblySearchPaths>$(SampleManager);$(SampleManager)SolutionAssemblies\;$(AssemblySearchPaths)</AssemblySearchPaths>
    <OutputPath>$(SampleManager)\SolutionAssemblies\</OutputPath>
    <DocumentationFile>$(OutputPath)Customization.ObjectModel.xml</DocumentationFile>
    <StartAction>Program</StartAction>
    <StartProgram>$(SampleManager)SampleManager.exe</StartProgram>
    <StartWorkingDirectory>$(SampleManager)</StartWorkingDirectory>
  </PropertyGroup>
</Project>